{
  "realm": "vellum",
  "enabled": true,
  "roles": {
    "realm": [
      { "name": "dev", "composite": false }
    ]
  },
  "clients": [
    {
      "clientId": "vellum",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "dev-secret",
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:7000/*"
      ],
      "webOrigins": ["*"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:5173/*##http://localhost:7000/*"
      },
      "protocolMappers": [
        {
          "name": "vellum roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "claim.name": "vellum_roles",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "user",
      "enabled": true,
      "email": "user@example.com",
      "firstName": "Dev",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "user",
          "temporary": false
        }
      ],
      "realmRoles": ["dev"]
    }
  ]
}
